{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": true,
    "strict": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2018", "ES2021.String"],
    "paths": {
      "obsidian-typings": ["node_modules/obsidian-typings/dist"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*.ts"]
}
